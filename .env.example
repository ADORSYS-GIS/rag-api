RAG_SERVER_BIND_ADDR=0.0.0.0:8080
RAG_MCP_BIND_ADDR=0.0.0.0:8081
LEGACY_PROXY_BIND_ADDR=0.0.0.0:8000

# ── mcp-gateway ────────────────────────────────────────────────────────────────
# Transport: "http" (default, exposes port 8090) or "stdio" (for Claude Desktop)
GATEWAY_TRANSPORT=http
GATEWAY_BIND_ADDR=0.0.0.0:8090
# Prepended to absolute local paths so the container can read host files.
# When compose mounts /:/host:ro, set this to /host.
GATEWAY_HOST_ROOT=/host
GATEWAY_PORT=8090

RAG_QDRANT_URL=http://localhost:6334
RAG_QDRANT_API_KEY=

RAG_REDIS_URL=redis://localhost:6379

RAG_OPENAI_COMPAT_BASE_URL=https://api.openai.com
RAG_OPENAI_COMPAT_API_KEY=
RAG_OPENAI_COMPAT_EMBEDDING_MODEL=text-embedding-3-small
